# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Rate Limiting (Public Endpoints)
RATE_LIMIT_PUBLIC_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_PUBLIC_MAX=100

# Rate Limiting (Authenticated Endpoints)
RATE_LIMIT_API_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_API_MAX=500

# Rate Limiting (Auth Endpoints - IP based)
RATE_LIMIT_AUTH_IP_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_AUTH_IP_MAX=50

# Rate Limiting (Auth Endpoints - Account Backoff)
RATE_LIMIT_AUTH_ACCOUNT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_AUTH_ACCOUNT_DELAY_AFTER=3
RATE_LIMIT_AUTH_ACCOUNT_DELAY_MS=1000 # Base delay, will scale exponentially
